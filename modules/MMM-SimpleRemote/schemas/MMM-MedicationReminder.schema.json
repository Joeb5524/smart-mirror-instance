{
  "type": "object",
  "additionalProperties": true,
  "required": ["medications"],
  "properties": {
    "medications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "dosage", "time"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "dosage": { "type": "string", "minLength": 1 },
          "time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
        }
      }
    },
    "alertWindowMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
    "missedGraceMinutes": { "type": "integer", "minimum": 0, "maximum": 10080 },
    "showRelative": { "type": "boolean" },
    "maxItems": { "type": "integer", "minimum": 1, "maximum": 50 }
  }
}